{
	"name": "DynamicJsonFileDataset",
	"properties": {
		"linkedServiceName": {
			"referenceName": "AzureDataLakeStorage1",
			"type": "LinkedServiceReference"
		},
		"parameters": {
			"File_Name": {
				"type": "string"
			}
		},
		"annotations": [],
		"type": "Json",
		"typeProperties": {
			"location": {
				"type": "AzureBlobFSLocation",
				"fileName": {
					"value": "@dataset().File_Name",
					"type": "Expression"
				},
				"folderPath": "input",
				"fileSystem": "adfdemo"
			}
		},
		"schema": {
			"type": "object",
			"properties": {
				"id": {
					"type": "string"
				},
				"name": {
					"type": "string"
				},
				"skills": {
					"type": "array",
					"items": {
						"type": "string"
					}
				},
				"Address": {
					"type": "object",
					"properties": {
						"state": {
							"type": "string"
						},
						"country": {
							"type": "string"
						},
						"zipcode": {
							"type": "string"
						}
					}
				},
				"Contact": {
					"type": "object",
					"properties": {
						"Phone": {
							"type": "string"
						},
						"email": {
							"type": "string"
						}
					}
				}
			}
		}
	}
}