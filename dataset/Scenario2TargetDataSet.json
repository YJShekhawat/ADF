{
	"name": "Scenario2TargetDataSet",
	"properties": {
		"linkedServiceName": {
			"referenceName": "AzureDataLakeStorage1",
			"type": "LinkedServiceReference"
		},
		"parameters": {
			"fileName": {
				"type": "string"
			}
		},
		"annotations": [],
		"type": "DelimitedText",
		"typeProperties": {
			"location": {
				"type": "AzureBlobFSLocation",
				"fileName": {
					"value": "@dataset().fileName",
					"type": "Expression"
				},
				"folderPath": "output/scenario2_output_files",
				"fileSystem": "adfdemo"
			},
			"columnDelimiter": ",",
			"escapeChar": "\\",
			"firstRowAsHeader": true,
			"quoteChar": "\""
		},
		"schema": [
			{
				"name": "emp_id",
				"type": "String"
			},
			{
				"name": "emp_name",
				"type": "String"
			},
			{
				"name": "salary",
				"type": "String"
			}
		]
	}
}