{
	"name": "Cast_DataFlow_Pipeline",
	"properties": {
		"activities": [
			{
				"name": "Data flow1",
				"type": "ExecuteDataFlow",
				"dependsOn": [],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"dataflow": {
						"referenceName": "Cast_Dataflow",
						"type": "DataFlowReference",
						"datasetParameters": {
							"sink1": {
								"File_Name": {
									"value": "@pipeline().parameters.Good_FileName",
									"type": "Expression"
								}
							},
							"sink2": {
								"File_Name": {
									"value": "@pipeline().parameters.Bad_FileName",
									"type": "Expression"
								}
							}
						}
					},
					"compute": {
						"coreCount": 8,
						"computeType": "General"
					},
					"traceLevel": "Fine"
				}
			}
		],
		"parameters": {
			"Good_FileName": {
				"type": "string",
				"defaultValue": "Good_FileName.csv"
			},
			"Bad_FileName": {
				"type": "string",
				"defaultValue": "Bad_FileName.csv"
			}
		},
		"annotations": []
	}
}