{
	"name": "DuplicateRemovalFlowletDatafow",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DynamicFileDataset",
						"type": "DatasetReference"
					},
					"name": "source1"
				},
				{
					"dataset": {
						"referenceName": "DynamicFileDataset",
						"type": "DatasetReference"
					},
					"name": "source2"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "DataFlowSinkDataSet",
						"type": "DatasetReference"
					},
					"name": "sink1"
				},
				{
					"dataset": {
						"referenceName": "DataFlowSinkDataSet",
						"type": "DatasetReference"
					},
					"name": "sink2"
				}
			],
			"transformations": [
				{
					"name": "flowlet1",
					"flowlet": {
						"referenceName": "DuplicateRemoveFlowlet",
						"type": "DataFlowReference"
					}
				},
				{
					"name": "flowlet2",
					"flowlet": {
						"referenceName": "DuplicateRemoveFlowlet",
						"type": "DataFlowReference"
					}
				},
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          id as string,",
				"          name as string,",
				"          gender as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source(output(",
				"          id as string,",
				"          name as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source2",
				"source1 compose(mapColumn(",
				"          id,",
				"          name,",
				"          gender",
				"     ),",
				"     composition: 'DuplicateRemoveFlowlet') ~> flowlet1@(output1)",
				"derivedColumn1 compose(mapColumn(",
				"          id,",
				"          name,",
				"          gender",
				"     ),",
				"     composition: 'DuplicateRemoveFlowlet') ~> flowlet2@(output1)",
				"source2 derive(gender = \"bcd\") ~> derivedColumn1",
				"flowlet1@output1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     partitionFileNames:['Employees_Flowlet_Output.csv'],",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     partitionBy('hash', 1)) ~> sink1",
				"flowlet2@output1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     partitionFileNames:['Department_Flowlet_Output.csv'],",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     mapColumn(",
				"          id,",
				"          name",
				"     ),",
				"     partitionBy('hash', 1)) ~> sink2"
			]
		}
	}
}