						"     SourceTableName as string (\"Countries\"),",
						"     TargetTableName as string (\"CountriesDW\")",
						"}",
						"source(output(",
						"          Id as integer,",
						"          Countries as string",
						"     ),",
						"     allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     enableNativeCdc: true,",
						"     netChanges: true,",
						"     skipInitialLoad: false,",
						"     isolationLevel: 'READ_UNCOMMITTED',",
						"     format: 'table') ~> source1",
						"source1 sink(allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     deletable:true,",
						"     insertable:true,",
						"     updateable:true,",
						"     upsertable:true,",
						"     keys:['Id'],",
						"     format: 'table',",
						"     skipDuplicateMapInputs: true,",
						"     skipDuplicateMapOutputs: true,",
						"     errorHandlingOption: 'stopOnFirstError') ~> sink1"
					]
				}
			},
			"dependsOn": []
		},
		{
			"name": "[concat(parameters('factoryName'), '/Cache_Sink_Dataflow')]",
			"type": "Microsoft.DataFactory/factories/dataflows",
			"apiVersion": "2018-06-01",
			"properties": {
				"type": "MappingDataFlow",
				"typeProperties": {
					"sources": [
						{
							"dataset": {
								"referenceName": "AzureSqlTableDataset",
								"type": "DatasetReference"
							},
							"name": "EmployeeSource"
						},
						{
							"dataset": {
								"referenceName": "DynamicFileDataset",
								"type": "DatasetReference"
							},
							"name": "FileSource"
						},
						{
							"dataset": {
								"referenceName": "AzureSqlTableDataset",
								"type": "DatasetReference"
							},
							"name": "CountryCodeSoure"
						}
					],
					"sinks": [
						{
							"name": "sink1"
						},
						{
							"dataset": {
								"referenceName": "AzureSqlTableDataset",
								"type": "DatasetReference"
							},
							"name": "EmployeeSink"
						},
						{
							"name": "countrycache"
						}
					],
					"transformations": [
						{
							"name": "SurrogateKey"
						},
						{
							"name": "derivedColumn1"
						}
					],
					"scriptLines": [
						"source(output(",
						"          MaxEmpId as integer",
						"     ),",
						"     allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     isolationLevel: 'READ_UNCOMMITTED',",
						"     query: 'SELECT max(empid) as MaxEmpId FROM Employees',",
						"     format: 'query') ~> EmployeeSource",
						"source(output(",
						"          empId as short,",
						"          name as string,",
						"          country as string",
						"     ),",
						"     allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     ignoreNoFilesFound: false,",
						"     partitionBy('hash', 1)) ~> FileSource",
						"source(output(",
						"          code as string,",
						"          country as string",
						"     ),",
						"     allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     isolationLevel: 'READ_UNCOMMITTED',",
						"     query: 'select * from countrycodes',",
						"     format: 'query') ~> CountryCodeSoure",
						"FileSource keyGenerate(output(EmpSurrogateKey as long),",
						"     startAt: 1L,",
						"     stepValue: 1L,",
						"     partitionBy('hash', 1)) ~> SurrogateKey",
						"SurrogateKey derive(NewEmpKey = sink1#outputs()[1].MaxEmpId + EmpSurrogateKey,",
						"          NewCountry = countrycache#lookup(country).countryname,",
