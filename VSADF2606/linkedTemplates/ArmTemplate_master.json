					"Event Based Trigger_properties_typeProperties_scope": {
						"value": "[parameters('Event Based Trigger_properties_typeProperties_scope')]"
					},
					"EventBasedTrigger_SetVariable_properties_Set_Variable_Pipeline_parameters_FileName": {
						"value": "[parameters('EventBasedTrigger_SetVariable_properties_Set_Variable_Pipeline_parameters_FileName')]"
					},
					"EventBasedTrigger_SetVariable_properties_typeProperties_scope": {
						"value": "[parameters('EventBasedTrigger_SetVariable_properties_typeProperties_scope')]"
					}
				}
			},
			"dependsOn": [
				"[resourceId('Microsoft.Resources/deployments', 'VSADF2606_ArmTemplate_2')]"
			]
		},
		{
			"name": "VSADF2606_ArmTemplate_4",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_4.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
